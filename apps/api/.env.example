# Server Environment Variables

# MongoDB credentials
DB_USER=your_mongodb_user
DB_PASSWORD=your_mongodb_password

# Optional: full MongoDB URI (overrides DB_USER/DB_PASSWORD if set)
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Optional: MongoDB connection parts (used when MONGO_URI is not set)
# DB_HOST=cluster0.xxxxx.mongodb.net
# DB_NAME=your_database_name
# DB_OPTIONS=retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret

# Data encryption
CRYPTO_SECRET=your_crypto_secret

# Server port
PORT=3000

# CORS origins separated by commas
# Example: http://localhost:3001,https://personal-yield-web.pages.dev
CORS_ALLOWED_ORIGINS=http://localhost:3001
