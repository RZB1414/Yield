{
  "name": "personal-yield",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Personal Yield — investment returns management (React frontend + Node.js/Express API)",
  "author": "Renan Buiatti",
  "license": "MIT",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run start --workspace=@personal-yield/client",
    "dev:server": "npm run dev --workspace=@personal-yield/server",
    "build:client": "npm run build --workspace=@personal-yield/client",
    "start:server": "npm run start --workspace=@personal-yield/server",
    "test:client": "npm run test --workspace=@personal-yield/client",
    "cf:api:dev": "npm run cf:dev --workspace=@personal-yield/server",
    "cf:whoami": "node ./scripts/run-with-env.mjs ./.env.cloudflare -- wrangler whoami",
    "cf:deploy:api": "node ./scripts/run-with-env.mjs ./.env.cloudflare -- npm run cf:deploy --workspace=@personal-yield/server",
    "cf:deploy:web": "node ./scripts/run-with-env.mjs ./.env.cloudflare -- npm run cf:deploy --workspace=@personal-yield/client"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "wrangler": "^4.75.0"
  }
}
