{
  "name": "personal-yield",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Personal Yield — investment returns management (React frontend + Node.js/Express API)",
  "author": "Renan Buiatti",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:client": "npm run start --workspace=@personal-yield/client",
    "dev:server": "npm run dev --workspace=@personal-yield/server",
    "build:client": "npm run build --workspace=@personal-yield/client",
    "start:server": "npm run start --workspace=@personal-yield/server",
    "test:client": "npm run test --workspace=@personal-yield/client",
    "snapshot": "npm run snapshot --workspace=@personal-yield/server",
    "seed:snapshots": "npm run seed:snapshots --workspace=@personal-yield/server"
  }
}
